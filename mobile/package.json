{
  "name": "csoai-mobile",
  "version": "3.1.0",
  "description": "CSOAI Capacitor mobile wrapper for iOS and Android",
  "private": true,
  "scripts": {
    "build:ios": "npx cap sync ios && npx cap build ios --release",
    "build:android": "npx cap sync android && cd android && ./gradlew bundleRelease",
    "sync": "npx cap sync",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "typescript": "^5.4.0"
  }
}
